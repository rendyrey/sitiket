NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# MySQL (see docker-compose.yml — `docker compose up -d` starts a matching local instance)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sitiket
DB_USER=sitiket
DB_PASSWORD=sitiket_dev_password
DB_ROOT_PASSWORD=sitiket_root_password

# Session auth: backend verifies a Google ID token, then issues its own JWT.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=
JWT_EXPIRES_IN=7d

# HMAC key used to sign each ticket's QR payload (separate from JWT_SECRET so QR tokens don't share a key with session auth).
QR_SIGNING_SECRET=

# Local disk storage for event images and payment-proof uploads in development.
UPLOAD_DIR=uploads

# Checkout timing
ORDER_PAYMENT_HOLD_MINUTES=60
GUEST_EMAIL_OTP_TTL_MINUTES=10

# Outgoing SMTP for the guest-checkout OTP email. Leave SMTP_HOST blank to
# skip sending — the OTP just logs server-side instead.
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
