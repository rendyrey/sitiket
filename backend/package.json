{
  "name": "sitiket-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "knex migrate:latest",
