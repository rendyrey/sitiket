    "google-auth-library": "^10.9.0",
    "image-size": "^1.2.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.3.0",
    "multer": "^2.2.0",
    "mysql2": "^3.23.0",
    "nodemailer": "^9.0.3",
    "zod": "^3.25.76"
  }
