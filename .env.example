# SiTIKET backend API origin (see backend/.env — must match its PORT).
API_BASE_URL=http://localhost:4000

# Public origin for backend-served assets (event images, payment proofs) the
# browser loads directly — usually the same value as API_BASE_URL, kept
# separate because a production deployment may route server-to-server API
# calls internally while assets need a publicly reachable origin.
NEXT_PUBLIC_API_ORIGIN=http://localhost:4000

# Google Identity Services client ID — public by design (Google client IDs are
# not secret), must match the backend's GOOGLE_CLIENT_ID for token verification
# to succeed. Leave blank to disable Google Sign-In until it's set.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
